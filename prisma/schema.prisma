generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")

}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String 
  fullName   String
  otp        String?  
  otpExpires DateTime?
  isVerified Boolean  @default(true) 
  createdAt  DateTime @default(now())
}