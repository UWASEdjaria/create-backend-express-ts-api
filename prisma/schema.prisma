generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  otp        String?
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  fullName   String
  otpExpires DateTime?
}
